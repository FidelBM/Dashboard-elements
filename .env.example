# Shared
NODE_ENV=development

# PostgreSQL
POSTGRES_USER=ml_app
POSTGRES_PASSWORD=ml_app_password
POSTGRES_DB=ml_reviews
POSTGRES_PORT=5432

# Application database URL for host-run Prisma commands
DATABASE_URL=postgresql://ml_app:ml_app_password@localhost:5432/ml_reviews?schema=public
DIRECT_URL=postgresql://ml_app:ml_app_password@localhost:5432/ml_reviews?schema=public

# Web
WEB_PORT=3000
NEXT_PUBLIC_ML_API_URL=http://localhost:8000
ML_API_INTERNAL_URL=http://ml-api:8000

# ML API
ML_API_PORT=8000
ML_API_ENV=development
USE_EXTERNAL_AI_RECOMMENDATIONS=false
